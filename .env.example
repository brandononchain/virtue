# Virtue v0.1 Environment Variables

# API
API_PORT=4000
API_HOST=localhost

# Provider keys (not required for mock provider)
LUMA_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Database (optional — Prisma scaffold only)
DATABASE_URL=postgresql://localhost:5432/virtue

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
